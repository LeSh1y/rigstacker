NODE_ENV=production
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=pcforge_user
DB_PASSWORD=change_me
DB_NAME=pc_backend

# Public frontend origin used when generating share URLs.
FRONTEND_URL=http://localhost:5173

# Redis cache is optional. Backend must still run if Redis is unavailable.
# Use REDIS_URL or the host/port/password fields below.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=250
CACHE_DEBUG=false

# Optional token for internal cache invalidation calls.
CACHE_INVALIDATION_TOKEN=change_me
